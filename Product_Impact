  CROSS JOIN params p
  WHERE t.snapshot_dt = p.dt_latest
),
detail AS (
  SELECT
    COALESCE(b.account_id, l.account_id) AS account_id,
    COALESCE(b.sub_category, l.sub_category) AS sub_category,
    COALESCE(b.sub_capability, l.sub_capability) AS sub_capability,
    COALESCE(b.custom_l1, l.custom_l1) AS custom_l1,
    b.shelfware AS shelfware_baseline,
    l.shelfware AS shelfware_latest,
    b.pov AS pov_baseline,
    l.pov AS pov_latest,
    b.pov_at_risk AS pov_at_risk_baseline,
    l.pov_at_risk AS pov_at_risk_latest,
    CASE
      WHEN b.account_id IS NULL THEN 'Mar_only'
      WHEN l.account_id IS NULL THEN 'Jan_only'
      ELSE 'Both_months'
    END AS period_coverage
  FROM baseline b
  FULL OUTER JOIN latest l
    ON b.account_id = l.account_id
   AND EQUAL_NULL(b.sub_category, l.sub_category)
   AND EQUAL_NULL(b.sub_capability, l.sub_capability)
   AND EQUAL_NULL(b.custom_l1, l.custom_l1)
),
from_line AS (
  SELECT *
  FROM detail
  WHERE period_coverage = 'Both_months'
    AND ZEROIFNULL(pov_baseline) > 0
    AND ZEROIFNULL(pov_latest) = 0
),
to_line AS (
  SELECT *
  FROM detail
  WHERE (period_coverage = 'Both_months'
         AND ZEROIFNULL(pov_baseline) = 0
         AND ZEROIFNULL(pov_latest) > 0)
     OR (period_coverage = 'Mar_only'
         AND ZEROIFNULL(pov_latest) > 0)
),
to_line_for_swap AS (
  SELECT t.*
  FROM to_line t
  CROSS JOIN params p
  WHERE NOT p.require_dest_absent_in_baseline
     OR t.period_coverage = 'Mar_only'
),
swap_accounts AS (
  SELECT DISTINCT f.account_id
  FROM from_line f
  WHERE EXISTS (SELECT 1 FROM to_line_for_swap t WHERE t.account_id = f.account_id)
),
from_af AS (
  SELECT f.*
  FROM from_line f
  INNER JOIN swap_accounts s ON s.account_id = f.account_id
  WHERE f.sub_category = 'Agentforce'
),
to_destination AS (
  SELECT
    t.account_id,
    t.sub_category AS swapped_to_sub_category,
    t.sub_capability AS swapped_to_sub_capability,
    t.custom_l1 AS swapped_to_custom_l1,
    MAX(ZEROIFNULL(t.pov_latest)) AS new_pov,
    MAX(ZEROIFNULL(t.shelfware_latest)) AS new_shelfware,
    MAX(t.period_coverage) AS to_line_period_coverage
  FROM to_line_for_swap t
  INNER JOIN (SELECT DISTINCT account_id FROM from_af) x ON x.account_id = t.account_id
  WHERE NOT EXISTS (
    SELECT 1
    FROM from_af ff
    WHERE ff.account_id = t.account_id
      AND EQUAL_NULL(ff.sub_category, t.sub_category)
