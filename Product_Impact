    t.custom_l1,
    t.snapshot_dt::DATE AS snapshot_dt,
    t.shelfware,
    t.pov,
    t.pov_at_risk
  FROM SSE_DM_CSG_RPT_PRD.OFFERS_DE.POV_WEIGHTED_SHELFWARE_TRENDING_VW t
  INNER JOIN target_accounts ta ON t.account_id = ta.account_id
  CROSS JOIN params p
  WHERE t.snapshot_dt::DATE IN (p.dt_baseline, p.dt_latest)
),
baseline AS (
  SELECT t.* FROM trending t CROSS JOIN params p WHERE t.snapshot_dt = p.dt_baseline
),
latest AS (
  SELECT t.* FROM trending t CROSS JOIN params p WHERE t.snapshot_dt = p.dt_latest
),
detail AS (
  SELECT
    COALESCE(b.account_id, l.account_id) AS account_id,
    COALESCE(b.sub_category, l.sub_category) AS sub_category,
    COALESCE(b.sub_capability, l.sub_capability) AS sub_capability,
    COALESCE(b.custom_l1, l.custom_l1) AS custom_l1,
    b.shelfware AS shelfware_baseline,
    l.shelfware AS shelfware_latest,
    b.pov AS pov_baseline,
    l.pov AS pov_latest,
    CASE
      WHEN b.account_id IS NULL THEN 'Mar_only'
      WHEN l.account_id IS NULL THEN 'Jan_only'
      ELSE 'Both_months'
    END AS period_coverage
  FROM baseline b
  FULL OUTER JOIN latest l
    ON b.account_id = l.account_id
   AND EQUAL_NULL(b.sub_category, l.sub_category)
   AND EQUAL_NULL(b.sub_capability, l.sub_capability)
   AND EQUAL_NULL(b.custom_l1, l.custom_l1)
),
from_line AS (
  SELECT * FROM detail
  WHERE period_coverage = 'Both_months'
    AND ZEROIFNULL(pov_baseline) > 0
    AND ZEROIFNULL(pov_latest) = 0
),
to_line AS (
  SELECT * FROM detail
  WHERE (period_coverage = 'Both_months'
         AND ZEROIFNULL(pov_baseline) = 0
         AND ZEROIFNULL(pov_latest) > 0)
     OR (period_coverage = 'Mar_only' AND ZEROIFNULL(pov_latest) > 0)
),
to_line_for_swap AS (
  SELECT t.*
  FROM to_line t
  CROSS JOIN params p
  WHERE NOT p.require_dest_absent_in_baseline
     OR t.period_coverage = 'Mar_only'
),
swap_accounts AS (
  SELECT DISTINCT f.account_id
  FROM from_line f
  WHERE EXISTS (SELECT 1 FROM to_line_for_swap t WHERE t.account_id = f.account_id)
),
from_af AS (
  SELECT f.* FROM from_line f
  INNER JOIN swap_accounts s ON s.account_id = f.account_id
  WHERE f.sub_category = 'Agentforce'
),
af_pov_by_acct AS (
  SELECT
    d.account_id,
    SUM(IFF(d.sub_category = 'Agentforce'
           AND d.period_coverage IN ('Both_months', 'Jan_only'),
           ZEROIFNULL(d.pov_baseline), 0)) AS pov_jan_af_sum,
    SUM(IFF(d.sub_category = 'Agentforce'
           AND d.period_coverage IN ('Both_months', 'Mar_only'),
           ZEROIFNULL(d.pov_latest), 0)) AS pov_mar_af_sum
  FROM detail d
  GROUP BY 1
),
account_swap_from_af AS (
  SELECT f.account_id,
    SUM(ZEROIFNULL(f.pov_baseline)) AS pov_swapped_off_af_lines,
    SUM(ZEROIFNULL(f.shelfware_baseline)) AS shelfware_on_af_from_lines_baseline
  FROM from_af f
  GROUP BY 1
),
acct_classified AS (
  SELECT
    a.account_id,
    a.pov_swapped_off_af_lines,
    a.shelfware_on_af_from_lines_baseline,
    z.pov_jan_af_sum,
    z.pov_mar_af_sum,
    CASE
      WHEN z.pov_jan_af_sum > 0 AND z.pov_mar_af_sum = 0 THEN 'Full_exit'
      WHEN z.pov_jan_af_sum > 0
           AND z.pov_mar_af_sum > 0
           AND z.pov_mar_af_sum < z.pov_jan_af_sum THEN 'Partial_exit'
      WHEN z.pov_jan_af_sum > 0 AND z.pov_mar_af_sum >= z.pov_jan_af_sum THEN 'No_reduction_or_increase'
      ELSE 'No_jan_af_pov'
    END AS af_pov_exit_type
  FROM account_swap_from_af a
  LEFT JOIN af_pov_by_acct z ON z.account_id = a.account_id
)
SELECT
  p.dt_baseline AS snapshot_baseline,
  p.dt_latest AS snapshot_latest,
  COUNT(DISTINCT c.account_id) AS n_accounts_swap_from_agentforce,
  SUM(c.pov_swapped_off_af_lines) AS sum_pov_swapped_off_af_lines,
  SUM(c.shelfware_on_af_from_lines_baseline) AS sum_shelfware_baseline_af_from_lines,
  COUNT_IF(c.af_pov_exit_type = 'Full_exit') AS n_accounts_full_af_exit,
  COUNT_IF(c.af_pov_exit_type = 'Partial_exit') AS n_accounts_partial_af_exit,
  COUNT_IF(c.af_pov_exit_type = 'No_reduction_or_increase') AS n_accounts_no_af_reduction,
  COUNT_IF(c.af_pov_exit_type = 'No_jan_af_pov') AS n_accounts_no_jan_af_pov
FROM acct_classified c
CROSS JOIN params p
;

/*------------------------------------------------------------------------------
  3) ONE ROW PER "SWAPPED TO" LINE — same rules as (1); with default params,
      only Mar_only (grain absent on baseline) + new POV on latest.
------------------------------------------------------------------------------*/
WITH params AS (
  SELECT
    DATE '2026-01-01' AS dt_baseline,
    DATE '2026-03-01' AS dt_latest,
    TRUE AS require_dest_absent_in_baseline
),
target_accounts AS (
  SELECT DISTINCT tl.account_id AS account_id
  FROM SSE_DM_CSG_RPT_PRD.RSPS_ANALYTICS.SHELFWARE_TARGET_LIST_FY27 tl
