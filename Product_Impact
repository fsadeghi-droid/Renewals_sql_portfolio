/* =============================================================================
   Shelfware trending + FY27 target list
   - Baseline vs latest snapshots (edit params)
   - Swap pattern: from_line (POV>0 -> 0) + to_line; by default to_line_for_swap keeps only
     Mar_only destinations (grain absent on baseline, POV>0 on latest) — "product not there before."
     Set require_dest_absent_in_baseline = FALSE to also allow Both_months (0 -> >0 POV on same grain).
   - Agentforce: sub_category = 'Agentforce' (confirm in DESC VIEW)
   - Query (4): all-product swap dashboard row per account (optional from_subcategory_filter).
   - "Swapped to" product = sub_category / sub_capability / custom_l1 on a to_line;
     new POV on latest snapshot: query (1) last column swapped_to_new_pov_usd only; see (3) for detail rows.
   ============================================================================= */

/*------------------------------------------------------------------------------
  1) CUSTOMER LIST — accounts with swap-from-Agentforce + metrics
------------------------------------------------------------------------------*/
WITH params AS (
  SELECT
    DATE '2026-01-01' AS dt_baseline,
    DATE '2026-03-01' AS dt_latest,
    /* TRUE: only destinations with no baseline row (Mar_only + POV>0 on latest).
       FALSE: also allow Both_months where baseline POV was 0 and latest POV > 0. */
    TRUE AS require_dest_absent_in_baseline
),

target_accounts AS (
  SELECT DISTINCT tl.account_id AS account_id
  FROM SSE_DM_CSG_RPT_PRD.RSPS_ANALYTICS.SHELFWARE_TARGET_LIST_FY27 tl
  WHERE tl.account_id IS NOT NULL
),

trending AS (
  SELECT
    t.account_id,
    t.sub_category,
    t.sub_capability,
    t.custom_l1,
    t.snapshot_dt::DATE AS snapshot_dt,
    t.shelfware,
    t.pov,
    t.pov_at_risk
  FROM SSE_DM_CSG_RPT_PRD.OFFERS_DE.POV_WEIGHTED_SHELFWARE_TRENDING_VW t
  INNER JOIN target_accounts ta ON t.account_id = ta.account_id
  CROSS JOIN params p
  WHERE t.snapshot_dt::DATE IN (p.dt_baseline, p.dt_latest)
),

baseline AS (
  SELECT t.*
  FROM trending t
  CROSS JOIN params p
  WHERE t.snapshot_dt = p.dt_baseline
),

latest AS (
  SELECT t.*
  FROM trending t
  CROSS JOIN params p
  WHERE t.snapshot_dt = p.dt_latest
),

detail AS (
  SELECT
    COALESCE(b.account_id, l.account_id) AS account_id,
    COALESCE(b.sub_category, l.sub_category) AS sub_category,
    COALESCE(b.sub_capability, l.sub_capability) AS sub_capability,
    COALESCE(b.custom_l1, l.custom_l1) AS custom_l1,
    b.shelfware AS shelfware_baseline,
    l.shelfware AS shelfware_latest,
    b.pov AS pov_baseline,
    l.pov AS pov_latest,
    b.pov_at_risk AS pov_at_risk_baseline,
    l.pov_at_risk AS pov_at_risk_latest,
    CASE
      WHEN b.account_id IS NULL THEN 'Mar_only'
      WHEN l.account_id IS NULL THEN 'Jan_only'
      ELSE 'Both_months'
    END AS period_coverage
  FROM baseline b
  FULL OUTER JOIN latest l
    ON b.account_id = l.account_id
   AND EQUAL_NULL(b.sub_category, l.sub_category)
   AND EQUAL_NULL(b.sub_capability, l.sub_capability)
   AND EQUAL_NULL(b.custom_l1, l.custom_l1)
),

from_line AS (
  SELECT *
  FROM detail
  WHERE period_coverage = 'Both_months'
    AND ZEROIFNULL(pov_baseline) > 0
    AND ZEROIFNULL(pov_latest) = 0
),

to_line AS (
  SELECT *
  FROM detail
  WHERE (period_coverage = 'Both_months'
         AND ZEROIFNULL(pov_baseline) = 0
         AND ZEROIFNULL(pov_latest) > 0)
     OR (period_coverage = 'Mar_only'
         AND ZEROIFNULL(pov_latest) > 0)
),

to_line_for_swap AS (
  SELECT t.*
  FROM to_line t
  CROSS JOIN params p
  WHERE NOT p.require_dest_absent_in_baseline
     OR t.period_coverage = 'Mar_only'
),

swap_accounts AS (
  SELECT DISTINCT f.account_id
  FROM from_line f
  WHERE EXISTS (SELECT 1 FROM to_line_for_swap t WHERE t.account_id = f.account_id)
),

from_af AS (
  SELECT f.*
  FROM from_line f
  INNER JOIN swap_accounts s ON s.account_id = f.account_id
  WHERE f.sub_category = 'Agentforce'
),

af_pov_by_acct AS (
  SELECT
    d.account_id,
    SUM(IFF(d.sub_category = 'Agentforce'
           AND d.period_coverage IN ('Both_months', 'Jan_only'),
           ZEROIFNULL(d.pov_baseline), 0)) AS pov_jan_af_sum,
    SUM(IFF(d.sub_category = 'Agentforce'
           AND d.period_coverage IN ('Both_months', 'Mar_only'),
           ZEROIFNULL(d.pov_latest), 0)) AS pov_mar_af_sum
  FROM detail d
  GROUP BY 1
),

account_swap_from_af AS (
  SELECT
    f.account_id,
    SUM(ZEROIFNULL(f.pov_baseline)) AS pov_swapped_off_af_lines,
    SUM(ZEROIFNULL(f.shelfware_baseline)) AS shelfware_on_af_from_lines_baseline,
    COUNT(*) AS af_from_line_cnt
  FROM from_af f
  GROUP BY 1
),

/* Destination lines = to_line_for_swap on same account as swap-from-AF, excluding the exact AF
   lines that went to zero (same grain). new_pov = POV on dt_latest for that line. */
to_destination AS (
  SELECT
    t.account_id,
    t.sub_category,
    t.sub_capability,
    t.custom_l1,
    MAX(ZEROIFNULL(t.pov_latest)) AS new_pov,
    MAX(ZEROIFNULL(t.shelfware_latest)) AS new_shelfware,
    MAX(t.period_coverage) AS to_line_period_coverage
  FROM to_line_for_swap t
  INNER JOIN (SELECT DISTINCT account_id FROM from_af) x ON x.account_id = t.account_id
  WHERE NOT EXISTS (
    SELECT 1
    FROM from_af ff
    WHERE ff.account_id = t.account_id
      AND EQUAL_NULL(ff.sub_category, t.sub_category)
      AND EQUAL_NULL(ff.sub_capability, t.sub_capability)
      AND EQUAL_NULL(ff.custom_l1, t.custom_l1)
  )
  GROUP BY 1, 2, 3, 4
),

to_products AS (
  SELECT
    account_id,
    LISTAGG(
      sub_category || ' / ' || COALESCE(sub_capability, '') || ' / ' || COALESCE(custom_l1, ''),
      ' || '
    ) WITHIN GROUP (
      ORDER BY sub_category, sub_capability, custom_l1
    ) AS swapped_to_products,
    /* Same row order as swapped_to_products; values only (POV $ on latest snapshot per line). */
    LISTAGG(
      '$' || TO_VARCHAR(ROUND(new_pov, 2)),
      ' || '
    ) WITHIN GROUP (
      ORDER BY sub_category, sub_capability, custom_l1
    ) AS swapped_to_new_pov_usd
  FROM to_destination
  GROUP BY account_id
)

SELECT
  p.dt_baseline AS snapshot_baseline,
  p.dt_latest AS snapshot_latest,
  a.account_id,
  z.pov_jan_af_sum,
  z.pov_mar_af_sum,
  CASE
    WHEN z.pov_jan_af_sum > 0 AND z.pov_mar_af_sum = 0 THEN 'Full_exit'
    WHEN z.pov_jan_af_sum > 0
         AND z.pov_mar_af_sum > 0
         AND z.pov_mar_af_sum < z.pov_jan_af_sum THEN 'Partial_exit'
    WHEN z.pov_jan_af_sum > 0 AND z.pov_mar_af_sum >= z.pov_jan_af_sum THEN 'No_reduction_or_increase'
    ELSE 'No_jan_af_pov'
  END AS af_pov_exit_type,
  a.pov_swapped_off_af_lines,
  a.shelfware_on_af_from_lines_baseline,
  a.af_from_line_cnt,
  tp.swapped_to_products,
  tp.swapped_to_new_pov_usd
FROM account_swap_from_af a
CROSS JOIN params p
LEFT JOIN af_pov_by_acct z ON z.account_id = a.account_id
LEFT JOIN to_products tp ON tp.account_id = a.account_id
ORDER BY a.pov_swapped_off_af_lines DESC NULLS LAST;

/*------------------------------------------------------------------------------
  2) SUMMARY KPIs — same logic, one rollup row
------------------------------------------------------------------------------*/
WITH params AS (
  SELECT
    DATE '2026-01-01' AS dt_baseline,
    DATE '2026-03-01' AS dt_latest,
    TRUE AS require_dest_absent_in_baseline
),
target_accounts AS (
  SELECT DISTINCT tl.account_id AS account_id
  FROM SSE_DM_CSG_RPT_PRD.RSPS_ANALYTICS.SHELFWARE_TARGET_LIST_FY27 tl
  WHERE tl.account_id IS NOT NULL
),
trending AS (
  SELECT
    t.account_id,
    t.sub_category,
